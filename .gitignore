.venv/
__pycache__/
*.pyc
.ipynb_checkpoints/

# Large raw capture data, video, and generated HTML reports.
# Kept locally on disk, not tracked in git (too large / regenerable).
*.mp4
*.html
*EVO*.txt
*iprj.txt
sites/Banks/sensors1_2.txt
sites/Banks/sensors3_4.txt

# .iprj files that are also test fixtures: tracked copies live in
# EVO/iprj_designer/tests/fixtures/, so the site-folder originals don't
# need to be tracked too.
sites/Banks/banks_1_2.iprj
sites/Banks/banks_3_4.iprj
sites/86_US95&SH8/us95&sh8.iprj

# Exception: tests/fixtures/ holds tracked copies of the above (and the EVO
# capture .txt files) despite the *EVO*.txt / *iprj.txt rules above.
!EVO/iprj_designer/tests/fixtures/*.txt
!EVO/iprj_designer/tests/fixtures/*.iprj

# iprj Designer generated test output (overlay PNGs, generated .iprj files)
EVO/iprj_designer/tests/out/

# iprj Designer Record panel: local host/credential overrides (ROADMAP Item 31)
EVO/iprj_designer/capture/hosts.local.json
